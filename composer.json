{
    "name": "haspadar/primus",
    "description": "Primitive wrappers for PHP: strong typing for strings, ints, arrays, and more",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Primus\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Primus\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Kanstantsinas Mesnikas",
            "email": "haspadar@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "~8.3.16 || ~8.4.3 || ~8.5.0"
    },
    "scripts": {
        "update-sheriff": "bash -c 'COMPOSER_ROOT_VERSION=$(git describe --tags --abbrev=0 | sed s/^v//) composer update haspadar/sheriff -W'"
    },
    "config": {
        "platform": {
            "php": "8.3.16"
        },
        "allow-plugins": {
            "infection/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require-dev": {
        "haspadar/sheriff": "^0.32.1"
    }
}
